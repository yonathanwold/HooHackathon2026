extends layout

block head
  meta(property='og:title', content='Tacitus Threads')
  meta(property='og:description', content='A living events desk for conflicts, launches, and breaking incidents.')

block content
  section.page-hero
    .page-hero-inner
      .page-copy.reveal
        .eyebrow Events Desk
        h1 A living board for what’s happening right now.
        p.lead Track conflicts, launches, cyberattacks, and breaking updates in one place so you always know what’s real and what’s shifting.
        .cta-row
          a.btn-primary(href='/tacitus') Open Reality Desk
          a.btn-ghost(href='/ask') Check Outlet Credibility
      .page-panel.reveal
        .panel-kicker Event Buckets
        ul.checklist
          li Conflicts & protests
          li Product & movie launches
          li Cyberattacks & outages

  section.section
    .section-head
      h2 Event Buckets
      p A simple organizer for what’s happening across categories.
    .event-filters
      .filter-group
        span.filter-label Category
        .filter-pills
          button.filter-pill.is-active(data-category='all') All
          button.filter-pill(data-category='conflicts') Conflicts
          button.filter-pill(data-category='releases') Releases
          button.filter-pill(data-category='cyber') Cyber
          button.filter-pill(data-category='politics') Politics
          button.filter-pill(data-category='business') Business
          button.filter-pill(data-category='science') Science
      .filter-group
        span.filter-label Region
        select#regionFilter.filter-select
          option(value='all') All regions
          option(value='na') North America
          option(value='eu') Europe
          option(value='latam') LatAm
          option(value='mea') MENA
          option(value='apac') APAC
      .filter-group
        span.filter-label Timeframe
        select#timeframeFilter.filter-select
          option(value='24h') Last 24 hours
          option(value='7d') Last 7 days
          option(value='30d') Last 30 days
    .thread-grid.event-buckets
      .thread-block.reveal
        h3
          i.fa-solid.fa-person-military-pointing
          | Conflicts & protests
        .thread-list#conflictsList
          .thread-item
            .thread-dot.conflict
            div Loading conflicts...
      .thread-block.reveal
        h3
          i.fa-solid.fa-film
          | Releases & launches
        .thread-list#releasesList
          .thread-item
            .thread-dot.gap
            div Loading releases...
      .thread-block.reveal
        h3
          i.fa-solid.fa-shield-halved
          | Cyberattacks & outages
        .thread-list#cyberList
          .thread-item
            .thread-dot.redflag
            div Loading cyber events...
      .thread-block.reveal
        h3
          i.fa-solid.fa-landmark
          | Politics & policy
        .thread-list#politicsList
          .thread-item
            .thread-dot.policy
            div Loading political events...
      .thread-block.reveal
        h3
          i.fa-solid.fa-chart-line
          | Business & economy
        .thread-list#businessList
          .thread-item
            .thread-dot.business
            div Loading business events...
      .thread-block.reveal
        h3
          i.fa-solid.fa-flask
          | Science & health
        .thread-list#scienceList
          .thread-item
            .thread-dot.science
            div Loading science events...
      .thread-block.reveal.thread-block--note
        h3
          i.fa-solid.fa-wand-magic-sparkles
          | Powered by Gemini
        p.event-note Results refresh based on filters and may take a few seconds.

  section.section
    .section-head
      h2 Event Tracking Flow
      p Capture updates, verify sources, and archive what’s resolved.
    .feature-grid
      .feature-card.reveal
        h4 Add an update
        p Log a new development with links and source notes.
      .feature-card.reveal
        h4 Verify and tag
        p Mark what’s confirmed, what’s disputed, and what’s still unverified.
      .feature-card.reveal
        h4 Resolve and archive
        p Close out events once verified so the desk stays clean.
